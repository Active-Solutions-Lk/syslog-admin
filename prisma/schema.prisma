generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model internal_log {
  id               Int      @id @default(autoincrement())
  related_table    String?  @db.VarChar(100)
  related_table_id Int?
  severity         Int
  message          String   @db.VarChar(500)
  admin_id         Int?
  action           String   @db.VarChar(100)
  status_code      Int
  additional_data  String?  @db.Text
  created_at       DateTime @default(now()) @db.Timestamp(0)
  updated_at       DateTime @default(now()) @db.Timestamp(0)
}

model admins {
  id           Int        @id @default(autoincrement())
  name         String?
  email        String     @unique(map: "User_email_key")
  passwordHash String?
  role         String?    @db.VarChar(50)
  status       Float
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  projects     projects[]

  @@index([id], map: "id")
}

model packages {
  id               Int        @id @default(autoincrement())
  name             String     @db.VarChar(50)
  log_count        Int
  log_duration     String     @db.VarChar(50)
  project_duration String     @db.VarChar(50)
  device_count     Int
  created_at       DateTime   @default(now()) @db.Timestamp(0)
  updated_at       DateTime   @default(now()) @db.Timestamp(0)
  projects         projects[]
}

model ports {
  id         Int        @id @default(autoincrement())
  port       Int
  created_at DateTime   @default(now()) @db.Timestamp(0)
  updated_at DateTime   @default(now()) @db.Timestamp(0)
  projects   projects[]
}

model projects {
  id              Int           @id @default(autoincrement())
  activation_key  String        @unique @db.VarChar(100)
  pkg_id          Int
  admin_id        Int?
  collector_ip    Int?
  logger_ip       Int?
  reseller_id     Int?
  created_at      DateTime      @default(now()) @db.Timestamp(0)
  updated_at      DateTime      @default(now()) @db.Timestamp(0)
  end_customer_id Int?
  port_id         Int?
  secret_key      String        @unique @db.VarChar(100)
  status          Boolean
  type            Int
  is_active_coll  Int           @db.TinyInt
  is_active_an    Int
  api_logs        api_logs[]
  admins          admins?       @relation(fields: [admin_id], references: [id], onDelete: Cascade, map: "fk_admin_id_admins_id")
  collector       collectors?   @relation(fields: [collector_ip], references: [id], map: "fk_collector_ip_collectors_id")
  logger          analyzers?    @relation(fields: [logger_ip], references: [id], map: "fk_logger_ip_logger_id")
  end_customer    end_customer? @relation(fields: [end_customer_id], references: [id], onDelete: Cascade, map: "fk_end_customer_id")
  packages        packages      @relation(fields: [pkg_id], references: [id], onDelete: Cascade, map: "fk_pkgid_package")
  port            ports?        @relation(fields: [port_id], references: [id], map: "fk_port_id_with_ports_id")
  project_type    project_types @relation(fields: [type], references: [id], map: "fk_project_type_id")
  reseller        reseller?     @relation(fields: [reseller_id], references: [customer_id], onDelete: Cascade, map: "fk_reseller_id_with_reseller_id")

  @@unique([collector_ip, port_id], map: "unique_collector_port")
  @@index([admin_id], map: "fk_admin_id_admins_id")
  @@index([reseller_id], map: "fk_reseller_id_with_reseller_id")
  @@index([pkg_id], map: "pkg_id")
  @@index([end_customer_id], map: "end_customer_id")
  @@index([port_id], map: "port_id")
  @@index([type], map: "fk_project_type_id_idx")
  @@index([collector_ip], map: "fk_collector_ip_collectors_id_idx")
  @@index([logger_ip], map: "fk_logger_ip_logger_id_idx")
}

model reseller {
  customer_id   Int        @id @default(autoincrement())
  company_name  String     @unique(map: "company_name") @db.VarChar(100)
  address       String?    @db.VarChar(250)
  type          String     @db.VarChar(100)
  credit_limit  String?    @db.VarChar(100)
  payment_terms String?    @db.VarChar(100)
  note          String?    @db.VarChar(250)
  vat           String?    @db.VarChar(11)
  city          Int?
  created_at    DateTime   @default(now()) @db.Timestamp(0)
  updated_at    DateTime   @default(now()) @db.Timestamp(0)
  projects      projects[]

  @@index([city], map: "city")
}

model session {
  id           String   @id
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expires      DateTime
  sessionToken String   @unique(map: "Session_sessionToken_key")

  @@index([userId], map: "Session_userId_fkey")
}

model end_customer {
  id             Int        @id @default(autoincrement())
  company        String?    @db.VarChar(50)
  address        String?    @db.VarChar(100)
  contact_person String     @db.VarChar(50)
  tel            Int
  email          String?    @db.VarChar(50)
  status         Boolean
  created_at     DateTime   @default(now()) @db.Timestamp(0)
  updated_at     DateTime   @default(now()) @db.Timestamp(0)
  projects       projects[]
}

model project_types {
  id       Int        @id @default(autoincrement())
  name     String?    @db.VarChar(10)
  projects projects[]
}

model collectors {
  id              Int        @id @default(autoincrement())
  name            String?    @db.VarChar(50)
  ip              String     @db.VarChar(100)
  domain          String?    @db.VarChar(50)
  secret_key      String?    @db.VarChar(100)
  last_fetched_id Int
  is_active       Boolean
  created_at      DateTime   @default(now()) @db.Timestamp(0)
  updated_at      DateTime   @default(now()) @db.Timestamp(0)
  projects        projects[]
}

model analyzers {
  id         Int        @id @default(autoincrement())
  name       String?    @db.VarChar(50)
  ip         String     @db.VarChar(50)
  domain     String?    @db.VarChar(50)
  status     Int        @db.TinyInt
  created_at DateTime   @default(now()) @db.Timestamp(0)
  updated_at DateTime   @default(now()) @db.Timestamp(0)
  projects   projects[]
}

model api_logs {
  id              Int      @id @unique(map: "id") @default(autoincrement())
  project_id      Int
  cpu_status      Int
  ram_status      Int
  log_count       Int
  type            String   @db.VarChar(20)
  device_count    Int
  last_login_date DateTime @default(now()) @db.Timestamp(0)
  description     String   @db.VarChar(100)
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @default(now()) @db.Timestamp(0)
  project         projects @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_project_id_with_projects_id")

  @@index([project_id], map: "project_id")
}
